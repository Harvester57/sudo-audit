{
  "Defaults": [
    {
      "Options": [
        { "visiblepw": true },
        { "use_pty": false },
        {
          "operation": "list_add",
          "env_keep": [ "LD_PRELOAD", "PYTHONPATH" ]
        }
      ]
    }
  ],
  "User_Specs": [
    {
      "User_List": [
        { "username": "bob" }
      ],
      "Host_List": [
        { "hostname": "ALL" }
      ],
      "Cmnd_Specs": [
        {
          "Options": [
            { "authenticate": false }
          ],
          "Commands": [
            { "command": "/usr/bin/find" },
            { "command": "/usr/bin/awk" },
            { "command": "/usr/bin/cat /var/log/*" },
            { "command": "/usr/bin/passwd", "negated": true },
            { "command": "/usr/bin/my-custom-utility-script --run" }
          ]
        }
      ]
    }
  ]
}
